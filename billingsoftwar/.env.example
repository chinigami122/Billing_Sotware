# Spring Boot
SERVER_CONTEXT_PATH=/api/v1.0

# Database
DB_URL=jdbc:mysql://localhost:3306/billing_app
DB_USERNAME=root
DB_PASSWORD=your_db_password
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# JWT
JWT_SECRET_KEY=replace_with_a_long_random_secret

# MinIO / S3
AWS_ACCESS_KEY=minioadmin
AWS_SECRET_KEY=minioadmin
AWS_REGION=us-east-1
AWS_BUCKET_NAME=billing-app

# Payment
STRIPE_API_KEY=sk_test_replace_with_your_stripe_key
# Optional legacy keys if still needed
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

